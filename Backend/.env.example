# Copy this file to `.env` and fill in real values for local dev.
# .env itself is git-ignored — never commit secrets.

# ---- Server ----
NODE_ENV=development
PORT=3000

# ---- MongoDB ----
# Local Mongo:
MONGODB_URI=mongodb://127.0.0.1:27017/genedy_metal_dev

# Atlas / production format:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/genedy_metal?retryWrites=true&w=majority

# ---- Auth ----
# Generate a long random string:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Required: must be at least 32 chars in production or the server refuses to boot.
JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Bcrypt work factor. 12 is the 2026 baseline. Bumping to 13 doubles cost.
BCRYPT_COST=12

# ---- CORS ----
# Comma-separated list of origins allowed to call the API.
# Example: https://genedymetal.com,https://www.genedymetal.com,http://localhost:5500
# In development you can use * to allow all origins.
CORS_ORIGINS=*
